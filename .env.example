# Vuelos (Duffel): https://duffel.com/
DUFFEL_ACCESS_TOKEN=duffel_test_XXXXXXXXX

# Hoteles: geoapify (por defecto), duffel (Stays), o rapidapi
# HOTELS_PROVIDER=geoapify
# HOTELS_PROVIDER=duffel
# HOTELS_PROVIDER=rapidapi

# --- RapidAPI (pestaña Hoteles cuando HOTELS_PROVIDER=rapidapi) ---
# Cuenta: https://rapidapi.com → X-RapidAPI-Key en "My Apps"
# En la API: Code snippets → X-RapidAPI-Host y la ruta GET de búsqueda (ej. /locations/v3/search)
# RAPIDAPI_KEY=
# RAPIDAPI_HOTEL_HOST=hotels4.p.rapidapi.com
# RAPIDAPI_SEARCH_PATH=/locations/v3/search
# Cómo construir la query: hotels_com (q+locale+currency) | dates (añade checkIn/checkOut/adults/rooms) | minimal (solo q)
# RAPIDAPI_QUERY_STYLE=hotels_com
# RAPIDAPI_LOCALE=en_US
# RAPIDAPI_CURRENCY=USD

# Prueba manual GET (misma clave/host): /api/hotels/rapidapi-test?... (requiere RAPIDAPI_TEST_PATH)
# RAPIDAPI_TEST_PATH=/v1/hotels/locations

# Solo si HOTELS_PROVIDER=geoapify — https://www.geoapify.com/
GEOAPIFY_API_KEY=tu_clave_geoapify

# Opcional: asistente de chat con OpenAI (si no hay clave, el chat usa respuestas locales)
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Túnel ngrok (solo si levantas con: docker compose --profile tunnel up -d)
# Token: https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=

# Docker: copia este archivo a .env en la misma carpeta que docker-compose.yml
